pipeline {
    agent any

    environment {
        REGISTRY = "10.0.2.13:5000"
        IMAGE = "app-rizky"
        TAG = "latest"
        FULL_IMAGE = "${REGISTRY}/${IMAGE}:${TAG}"

        VM1 = "10.0.1.11"
        VM2 = "10.0.1.12"
        VM_HA = "10.0.2.13"
        KEY = "/root/server-1.pem"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/RizkyAff/app-iky-belajar1.git'
            }
        }

        stage('Build Image') {
            steps {
                sh "docker build -t ${FULL_IMAGE} ./app"
            }
        }

        stage('Push Image') {
            steps {
                sh "docker push ${FULL_IMAGE}"
            }
        }

        stage('Deploy Zero Downtime') {
            steps {
                script {
                    def servers = [
                        [name: "vm1", ip: VM1, path: "/home/ubuntu/dckr11"],
                        [name: "vm2", ip: VM2, path: "/home/ubuntu/dckr12"]
                    ]

                    for (srv in servers) {

                        echo "===== DEPLOY ${srv.name} ====="

                        // 🔴 Disable HAProxy
                        sh """
                        ssh -i $KEY ubuntu@${VM_HA} \
                        "echo 'disable server app_servers/${srv.name}' | sudo socat stdio /run/haproxy/admin.sock"
                        """

                        // 🔥 SYNC CONFIG (INI YANG SEBELUMNYA KURANG)
                        sh """
                        scp -i $KEY docker/docker-compose.yml ubuntu@${srv.ip}:${srv.path}/docker-compose.yml
                        """

                        // 🔥 DEPLOY FULL CLEAN
                        sh """
                        ssh -i $KEY ubuntu@${srv.ip} "
                        cd ${srv.path} &&
                        docker-compose down &&
                        docker-compose pull &&
                        docker-compose up -d --remove-orphans
                        "
                        """

                        sleep 10

                        // 🟢 Enable HAProxy lagi
                        sh """
                        ssh -i $KEY ubuntu@${VM_HA} \
                        "echo 'enable server app_servers/${srv.name}' | sudo socat stdio /run/haproxy/admin.sock"
                        """

                        sleep 5
                    }
                }
            }
        }
    }
}