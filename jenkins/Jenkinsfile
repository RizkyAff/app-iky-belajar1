pipeline {
    agent any

    environment {
        REGISTRY = "10.0.2.13:5000"
        IMAGE = "app-iky"
        TAG = "${BUILD_NUMBER}"
        FULL_IMAGE = "${REGISTRY}/${IMAGE}:${TAG}"
        PREV_IMAGE = "${REGISTRY}/${IMAGE}:previous"
        KEY = "/root/server-1.pem"

        VM_HA = "10.0.2.13"
        VM1 = "10.0.1.11"
        VM2 = "10.0.1.12"
    }

    stages {

        stage('Build Image') {
            steps {
                sh 'docker build -t $IMAGE:$TAG ./app'
            }
        }

        stage('Tag & Push Image') {
            steps {
                sh '''
                docker tag $IMAGE:$TAG $FULL_IMAGE
                docker tag $IMAGE:$TAG $REGISTRY/$IMAGE:latest
                docker push $FULL_IMAGE
                docker push $REGISTRY/$IMAGE:latest
                '''
            }
        }

        stage('Sync Config') {
            steps {
                script {
                    def servers = [
                        [ip: VM1, path: "/home/ubuntu/dckr11", monitoring: true],
                        [ip: VM2, path: "/home/ubuntu/dckr12", monitoring: false]
                    ]

                    for (srv in servers) {

                        sh """
                        ssh -i $KEY -o StrictHostKeyChecking=no ubuntu@${srv.ip} \
                        "mkdir -p ${srv.path}/proxy"
                        """

                        sh """
                        scp -i $KEY -o StrictHostKeyChecking=no ${WORKSPACE}/docker/docker-compose.yml \
                        ubuntu@${srv.ip}:${srv.path}/
                        """

                        sh """
                        scp -i $KEY -o StrictHostKeyChecking=no ${WORKSPACE}/proxy/nginx.conf \
                        ubuntu@${srv.ip}:${srv.path}/proxy/
                        """

                        if (srv.monitoring) {
                            sh """
                            scp -i $KEY -o StrictHostKeyChecking=no ${WORKSPACE}/monitoring/docker-compose.monitor.yml \
                            ubuntu@${srv.ip}:${srv.path}/
                            scp -i $KEY -o StrictHostKeyChecking=no -r ${WORKSPACE}/monitoring \
                            ubuntu@${srv.ip}:${srv.path}/
                            """
                        }
                    }
                }
            }
        }

        stage('Deploy Zero Downtime') {
            steps {
                script {

                    def servers = [
                        [name: "vm1", ip: VM1, path: "/home/ubuntu/dckr11", monitoring: true],
                        [name: "vm2", ip: VM2, path: "/home/ubuntu/dckr12", monitoring: false]
                    ]

                    for (srv in servers) {

                        // 🔻 Disable dari HAProxy
                        echo "=== Disable ${srv.name} from HAProxy ==="
                        sh """
                        ssh -i $KEY -o StrictHostKeyChecking=no ubuntu@${VM_HA} \
                        "echo 'disable server app_servers/${srv.name}' | sudo socat stdio /run/haproxy/admin.sock"
                        """

                        // 🔁 Backup image
                        echo "=== Backup image (${srv.name}) ==="
                        sh """
                        ssh -i $KEY ubuntu@${srv.ip} "
                        docker pull ${REGISTRY}/${IMAGE}:latest &&
                        docker tag ${REGISTRY}/${IMAGE}:latest ${PREV_IMAGE} &&
                        docker push ${PREV_IMAGE}
                        "
                        """

                        // 🚀 Deploy (tanpa health check kompleks)
                        echo "=== Deploy ${srv.name} ==="
                        if (srv.monitoring) {
                            sh """
                            ssh -i $KEY ubuntu@${srv.ip} "
                            cd ${srv.path} &&
                            sed -i 's|image:.*|image: ${FULL_IMAGE}|' docker-compose.yml &&
                            docker-compose pull &&
                            docker-compose -f docker-compose.yml -f docker-compose.monitor.yml up -d --remove-orphans
                            "
                            """
                        } else {
                            sh """
                            ssh -i $KEY ubuntu@${srv.ip} "
                            cd ${srv.path} &&
                            sed -i 's|image:.*|image: ${FULL_IMAGE}|' docker-compose.yml &&
                            docker-compose pull &&
                            docker-compose up -d --remove-orphans
                            "
                            """
                        }

                        // ⏳ Delay sederhana (AMAN)
                        sleep 10

                        // 🔼 Enable kembali
                        echo "=== Enable ${srv.name} back ==="
                        sh """
                        ssh -i $KEY ubuntu@${VM_HA} \
                        "echo 'enable server app_servers/${srv.name}' | sudo socat stdio /run/haproxy/admin.sock"
                        """

                        sleep 5
                    }
                }
            }
        }
    }
}