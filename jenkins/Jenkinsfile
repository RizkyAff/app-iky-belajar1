stage('Deploy Zero Downtime') {
steps {
script {
    
        def servers = [
            [name: "vm1", ip: VM1, path: "/home/ubuntu/dckr11", monitoring: true],
            [name: "vm2", ip: VM2, path: "/home/ubuntu/dckr12", monitoring: false]
        ]

        for (srv in servers) {

            echo "Disable ${srv.name}"
            sh "echo 'disable server app_servers/${srv.name}' | socat stdio /run/haproxy/admin.sock"

            sleep(5)

            echo "Deploy ${srv.name}"
            if (srv.monitoring) {
                sh """
                ssh -i $KEY ubuntu@${srv.ip} "
                cd ${srv.path} &&
                docker-compose pull || true &&
                docker-compose -f docker-compose.yml -f docker-compose.monitor.yml up -d --remove-orphans
                "
                """
            } else {
                sh """
                ssh -i $KEY ubuntu@${srv.ip} "
                cd ${srv.path} &&
                docker-compose up -d --remove-orphans
                "
                """
            }

            sleep(5)

            echo "Enable ${srv.name}"
            sh "echo 'enable server app_servers/${srv.name}' | socat stdio /run/haproxy/admin.sock"

            sleep(5)
        }
    }
}

}
